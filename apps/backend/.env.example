PORT=3001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/sims

# Auth
JWT_SECRET=change-me

# Redis (optional - BullMQ)
REDIS_URL=redis://localhost:6379

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Alternative for SMTP_PASS
SMTP_PASSWORD=
# Optional for SMTP mode (defaults by port: 465 => true, others => false)
SMTP_SECURE=

# Resend (recommended on cloud deployments)
RESEND_API_KEY=
RESEND_FROM=

# VNPay (optional - payments)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/customer/contracts

# Google Gemini (SIMS Assistant chatbot)
# Get a key at https://aistudio.google.com/
GEMINI_API_KEY=
# Optional: gemini-2.5-flash (default), gemini-2.0-flash, gemini-1.5-flash, etc.
GEMINI_MODEL=gemini-2.5-flash

